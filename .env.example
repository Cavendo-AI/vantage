# Vantage Configuration
PORT=3020
NODE_ENV=development

# Database
DB_DRIVER=sqlite
ALLOW_SQLITE=true
DATABASE_PATH=./data/vantage.db

# CORS
CORS_ORIGIN=http://localhost:5173

# Optional: required for creating the very first API key from a non-localhost client.
# Send the same value in the X-Vantage-Bootstrap-Token header on POST /api/auth/keys.
VANTAGE_BOOTSTRAP_TOKEN=
